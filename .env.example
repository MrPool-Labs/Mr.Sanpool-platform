# Banco PostgreSQL local de exemplo.
# Ajuste user, password e database conforme o seu ambiente.
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/mrsanpool

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

